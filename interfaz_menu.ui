        <widget class="QScrollArea" name="layout_canciones2">
         <property name="styleSheet">
          <string notr="true">/* Estilo general para el área de scroll */
QScrollArea {
    border: none;
    background-color: transparent;
}

/* Barra de desplazamiento vertical */
QScrollBar:vertical {
    border: none;
    background: #121212; /* Fondo de la barra */
    width: 10px;
    margin: 0px 0px 0px 0px;
    border-radius: 5px;
}

/* El &quot;tirador&quot; (la parte que se mueve) */
QScrollBar::handle:vertical {
    background: #444; /* Color gris oscuro por defecto */
    min-height: 30px;
    border-radius: 5px;
}

/* Color cuando pasas el mouse por encima (Celeste Neon) */
QScrollBar::handle:vertical:hover {
    background: #00d2ff; 
}

/* Color cuando lo estás arrastrando */
QScrollBar::handle:vertical:pressed {
    background: #00a0c4;
}

/* Eliminar las flechas de arriba y abajo */
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}

/* Eliminar el fondo que queda arriba y abajo del tirador */
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

/* Opcional: Si también usas scroll horizontal */
QScrollBar:horizontal {
    border: none;
    background: #121212;
    height: 10px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background: #444;
    border-radius: 5px;
}

QScrollBar::handle:horizontal:hover {
    background: #00d2ff;
}</string>
         </property>
